{
	"name": "@typecarta/benchmarks",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"bench:scorecard": "tsx scorecard-perf/index.ts",
		"bench:coverage": "tsx adapter-coverage/index.ts",
		"bench:fidelity": "tsx encoding-fidelity/index.ts",
		"bench:all": "pnpm run bench:scorecard && pnpm run bench:coverage && pnpm run bench:fidelity",
