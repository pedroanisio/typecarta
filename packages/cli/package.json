{
	"name": "@typecarta/cli",
	"version": "0.1.0",
	"description": "Command-line interface for typecarta",
	"type": "module",
	"bin": {
		"typecarta": "./dist/index.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@typecarta/adapter-avro": "workspace:*",
		"@typecarta/adapter-effect-schema": "workspace:*",
		"@typecarta/adapter-graphql": "workspace:*",
		"@typecarta/adapter-json-schema": "workspace:*",
		"@typecarta/adapter-protobuf": "workspace:*",
		"@typecarta/adapter-shacl": "workspace:*",
		"@typecarta/adapter-typescript": "workspace:*",
		"@typecarta/adapter-xsd": "workspace:*",
		"@typecarta/adapter-xsd-1-1": "workspace:*",
		"@typecarta/adapter-zod": "workspace:*",
		"@typecarta/core": "workspace:*",
		"@typecarta/witnesses": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
