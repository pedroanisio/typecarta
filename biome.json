{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": { "enabled": true },
	"files": {
		"ignore": ["coverage/**", "docs/api/**", "node_modules/**", "dist/**"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noThenProperty": "off",
				"noControlCharactersInRegex": "off",
				"noShadowRestrictedNames": "off",
				"noExplicitAny": "off"
			}
		}
	}
}
