{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"lib": ["ES2022"],
		"strict": true,
		"exactOptionalPropertyTypes": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"declaration": true
	},
	"include": [
		"packages/core/src/**/*.ts",
		"packages/witnesses/src/**/*.ts",
		"packages/adapters/json-schema/src/**/*.ts",
		"packages/encoding-check/src/**/*.ts"
	]
}
